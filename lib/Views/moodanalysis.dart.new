      decoration: BoxDecoration(
        color: Colors.white.withOpacity(0.1),
        borderRadius: BorderRadius.circular(16),
        boxShadow: [
          BoxShadow(
            color: Colors.black.withOpacity(0.1),
            blurRadius: 10,
            offset: const Offset(0, 5),
          ),
        ],
      ),
      child: ClipRRect(
        borderRadius: BorderRadius.circular(16),
        child: BackdropFilter(
          filter: ImageFilter.blur(sigmaX: 10.0, sigmaY: 10.0),
          child: Padding(
            padding: const EdgeInsets.all(16.0),
            child: Column(
              crossAxisAlignment: CrossAxisAlignment.start,
              children: [
                Row(
                  mainAxisAlignment: MainAxisAlignment.spaceBetween,
                  children: [
                    const Text(
                      'Psychological Test Scores',
                      style: TextStyle(
                        color: Colors.white,
                        fontSize: 18,
                        fontWeight: FontWeight.bold,
                      ),
                    ),
                    IconButton(
                      icon: const Icon(Icons.info_outline, color: Colors.white),
                      onPressed: () {
                        // Show information about psychological tests
                        showDialog(
                          context: context,
                          builder: (context) => AlertDialog(
                            title: const Text('About Psychological Tests'),
                            content: const Text(
                                'These scores represent standardized psychological assessments used to measure aspects of mental health. Lower scores on anxiety and depression scales indicate better mental health, while higher scores on well-being scales are positive.'),
                            actions: [
                              TextButton(
                                onPressed: () => Navigator.of(context).pop(),
                                child: const Text('Close'),
                              ),
                            ],
                          ),
                        );
                      },
                    ),
                  ],
                ),
                const SizedBox(height: 12),
                _buildPsychTestScoreItem('Depression Scale (PHQ-9)', 7, 27, Colors.blue),
                const SizedBox(height: 8),
                _buildPsychTestScoreItem('Anxiety Scale (GAD-7)', 5, 21, Colors.purple),
                const SizedBox(height: 8),
                _buildPsychTestScoreItem('Well-being Index', 15, 25, Colors.green),
                const SizedBox(height: 8),
                _buildPsychTestScoreItem('Stress Scale (PSS-10)', 12, 40, Colors.orange),
                const SizedBox(height: 12),
                Center(
                  child: TextButton.icon(
                    icon: const Icon(Icons.assessment, color: secondaryColor),
                    label: const Text(
                      'Take New Assessment',
                      style: TextStyle(color: secondaryColor),
                    ),
                    onPressed: () {
                      // TODO: Navigate to psychological assessment
                    },
                  ),
                ),
              ],
            ),
          ),
        ),
      ),
    );
  }

  Widget _buildPsychTestScoreItem(
      String title, int score, int maxScore, Color color) {
    final double percentage = score / maxScore;
    
    return Column(
      crossAxisAlignment: CrossAxisAlignment.start,
      children: [
        Row(
          mainAxisAlignment: MainAxisAlignment.spaceBetween,
          children: [
            Text(
              title,
              style: const TextStyle(
                color: Colors.white,
                fontSize: 14,
              ),
            ),
            Text(
              '$score / $maxScore',
              style: const TextStyle(
                color: Colors.white,
                fontWeight: FontWeight.bold,
                fontSize: 14,
              ),
            ),
          ],
        ),
        const SizedBox(height: 6),
        Container(
          height: 8,
          decoration: BoxDecoration(
            color: Colors.white.withOpacity(0.2),
            borderRadius: BorderRadius.circular(4),
          ),
          child: FractionallySizedBox(
            alignment: Alignment.centerLeft,
            widthFactor: percentage,
            child: Container(
              decoration: BoxDecoration(
                color: color,
                borderRadius: BorderRadius.circular(4),
              ),
            ),
          ),
        ),
      ],
    );
  }

