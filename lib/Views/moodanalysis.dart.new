  Widget _buildTimeFrameSelector() {
    return Container(
      padding: const EdgeInsets.symmetric(horizontal: 8, vertical: 4),
      decoration: BoxDecoration(
        color: Colors.white.withOpacity(0.1),
        borderRadius: BorderRadius.circular(20),
      ),
      child: Row(
        children: timeFrames.map((timeFrame) {
          final isSelected = timeFrame == selectedTimeFrame;
          return GestureDetector(
            onTap: () => _selectTimeFrame(timeFrame),
            child: Container(
              padding: const EdgeInsets.symmetric(horizontal: 12, vertical: 6),
              decoration: BoxDecoration(
                color: isSelected ? secondaryColor : Colors.transparent,
                borderRadius: BorderRadius.circular(20),
              ),
              child: Text(
                timeFrame,
                style: TextStyle(
                  color: isSelected ? Colors.white : Colors.white.withOpacity(0.7),
                  fontWeight: isSelected ? FontWeight.bold : FontWeight.normal,
                ),
              ),
            ),
          );
        }).toList(),
      ),
    );
  }

  Widget _buildLineChart() {
    // Select the right data based on the time frame
    List<FlSpot> spots;
    String timeFormat;
    double maxX;
    double interval;

    switch (selectedTimeFrame) {
      case 'Week':
        spots = _weeklySpots;
        timeFormat = 'd MMM';
        maxX = 7;
        interval = 1;
        break;
      case 'Month':
        spots = _monthlySpots;
        timeFormat = 'd';
        maxX = 30;
        interval = 5;
        break;
      case 'Year':
        spots = _yearlySpots;
        timeFormat = 'MMM';
        maxX = 365;
        interval = 30;
        break;
      default:
        spots = _weeklySpots;
        timeFormat = 'd MMM';
        maxX = 7;
        interval = 1;
    }

    if (spots.isEmpty) {
      return const Center(
        child: Text(
          "No data available for this time frame",
          style: TextStyle(color: Colors.white70),
        ),
      );
    }

    return LineChart(
      LineChartData(
        gridData: FlGridData(show: false),
        titlesData: FlTitlesData(
          rightTitles: AxisTitles(
            sideTitles: SideTitles(showTitles: false),
          ),
          topTitles: AxisTitles(
            sideTitles: SideTitles(showTitles: false),
          ),
          bottomTitles: AxisTitles(
            sideTitles: SideTitles(
              showTitles: true,
              getTitlesWidget: (value, meta) {
                if (value % interval != 0) return const Text('');
                
                // Format based on time frame
                final now = DateTime.now();
                DateTime date;
                
                if (selectedTimeFrame == 'Week') {
                  date = now.subtract(Duration(days: (maxX - value).toInt()));
                } else if (selectedTimeFrame == 'Month') {
                  date = now.subtract(Duration(days: (maxX - value).toInt()));
                } else { // Year
                  // For year, show month names every 30 days
                  date = now.subtract(Duration(days: (maxX - value).toInt()));
                }
                
                return Padding(
                  padding: const EdgeInsets.only(top: 8.0),
                  child: Text(
                    DateFormat(timeFormat).format(date),
                    style: TextStyle(
                      color: Colors.white.withOpacity(0.7),
                      fontSize: 10,
                    ),
                  ),
                );
              },
            ),
          ),
          leftTitles: AxisTitles(
            sideTitles: SideTitles(
              showTitles: true,
              interval: 1,
              getTitlesWidget: (value, meta) {
                String text;
                if (value == 0) {
                  text = 'Very-';
                } else if (value == 1) {
                  text = 'Neg';
                } else if (value == 3) {
                  text = 'Neu';
                } else if (value == 5) {
                  text = 'Pos';
                } else if (value == 6) {
                  text = 'Very+';
                } else {
                  return const Text('');
                }
                
                return Text(
                  text,
                  style: TextStyle(
                    color: Colors.white.withOpacity(0.7),
                    fontSize: 10,
                  ),
                );
              },
            ),
          ),
        ),
        borderData: FlBorderData(show: false),
        minX: 0,
        maxX: maxX,
        minY: 0,
        maxY: 6,
        lineBarsData: [
          LineChartBarData(
            spots: spots,
            isCurved: true,
            gradient: const LinearGradient(
              colors: [secondaryColor, Colors.purple],
            ),
            barWidth: 3,
            isStrokeCapRound: true,
            dotData: FlDotData(
              show: true,
              getDotPainter: (spot, percent, barData, index) {
                return FlDotCirclePainter(
                  radius: 4,
                  color: Colors.white,
                  strokeWidth: 2,
                  strokeColor: secondaryColor,
                );
              },
            ),
            belowBarData: BarAreaData(
              show: true,
              gradient: LinearGradient(
                colors: [
                  secondaryColor.withOpacity(0.3),
                  Colors.purple.withOpacity(0.0)
                ],
                begin: Alignment.topCenter,
                end: Alignment.bottomCenter,
              ),
            ),
          ),
        ],
      ),
    );
  }

  Widget _buildSentimentHistoryCard() {
    return Container(
      decoration: BoxDecoration(
        color: Colors.white.withOpacity(0.1),
        borderRadius: BorderRadius.circular(16),
        boxShadow: [
          BoxShadow(
            color: Colors.black.withOpacity(0.1),
            blurRadius: 10,
            offset: const Offset(0, 5),
          ),
        ],
      ),
      child: ClipRRect(
        borderRadius: BorderRadius.circular(16),
        child: BackdropFilter(
          filter: ImageFilter.blur(sigmaX: 10.0, sigmaY: 10.0),
          child: Padding(
            padding: const EdgeInsets.all(16.0),
            child: Column(
              crossAxisAlignment: CrossAxisAlignment.start,
              children: [
                Row(
                  mainAxisAlignment: MainAxisAlignment.spaceBetween,
                  children: [
                    const Text(
                      'Recent Sentiment History',
                      style: TextStyle(
                        color: Colors.white,
                        fontSize: 18,
                        fontWeight: FontWeight.bold,
                      ),
                    ),
                    IconButton(
                      icon: const Icon(Icons.refresh, color: Colors.white),
                      onPressed: _loadSentimentData,
                    ),
                  ],
                ),
                const SizedBox(height: 16),
                StreamBuilder<QuerySnapshot>(
                  stream: _sentimentStream,
                  builder: (context, snapshot) {
                    if (snapshot.connectionState == ConnectionState.waiting && !snapshot.hasData) {
                      return const Center(
                        child: Padding(
                          padding: EdgeInsets.all(20.0),
                          child: CircularProgressIndicator(color: Colors.white),
                        ),
                      );
                    }

                    if (snapshot.hasError) {
                      return Center(
                        child: Text(
                          'Error: ${snapshot.error}',
                          style: const TextStyle(color: Colors.white70),
                        ),
                      );
                    }

                    final docs = snapshot.data?.docs;
                    if (docs == null || docs.isEmpty) {
                      return const Center(
                        child: Padding(
                          padding: EdgeInsets.all(20.0),
                          child: Text(
                            'No sentiment data found. Start chatting with the therapy assistant to generate sentiment data.',
                            style: TextStyle(color: Colors.white70),
                            textAlign: TextAlign.center,
                          ),
                        ),
                      );
                    }

                    return ListView.builder(
                      shrinkWrap: true,
                      physics: const NeverScrollableScrollPhysics(),
                      itemCount: docs.length,
                      itemBuilder: (context, index) {
                        final item = docs[index].data() as Map<String, dynamic>;
                        return _buildSentimentHistoryItemFixed(
                          text: item['text'] ?? 'No text',
                          sentiment: item['sentiment'] ?? 'neu',
                          timestamp: item['timestamp'] as Timestamp?,
                        );
                      },
                    );
                  },
                ),
              ],
            ),
          ),
        ),
      ),
    );
  }

  Widget _buildSummaryCard() {
    return Container(
      decoration: BoxDecoration(
        color: Colors.white.withOpacity(0.1),
        borderRadius: BorderRadius.circular(16),
        boxShadow: [
          BoxShadow(
            color: Colors.black.withOpacity(0.1),
            blurRadius: 10,
            offset: const Offset(0, 5),
          ),
        ],
      ),
      child: ClipRRect(
        borderRadius: BorderRadius.circular(16),
        child: BackdropFilter(
          filter: ImageFilter.blur(sigmaX: 10.0, sigmaY: 10.0),
          child: Padding(
            padding: const EdgeInsets.all(16.0),
            child: Column(
              crossAxisAlignment: CrossAxisAlignment.start,
              children: [
                const Text(
                  'Chat Summary',
                  style: TextStyle(
                    color: Colors.white,
                    fontSize: 18,
                    fontWeight: FontWeight.bold,
                  ),
                ),
                const SizedBox(height: 16),
                if (_isSummarizing)
                  const Center(
                    child: Padding(
                      padding: EdgeInsets.all(20.0),
                      child: CircularProgressIndicator(color: Colors.white),
                    ),
                  )
                else if (_chatSummary != null)
                  Text(
                    _chatSummary!,
                    style: const TextStyle(
                      color: Colors.white,
                      fontSize: 14,
                    ),
                  )
                else
                  const Center(
                    child: Padding(
                      padding: EdgeInsets.all(20.0),
                      child: Text(
                        'No summary generated yet. Generate one to see an analysis of your recent conversations.',
                        style: TextStyle(color: Colors.white70),
                        textAlign: TextAlign.center,
                      ),
                    ),
                  ),
                const SizedBox(height: 16),
                Center(
                  child: ElevatedButton(
                    onPressed: _isSummarizing ? null : _summarizeChatHistory,
                    style: ElevatedButton.styleFrom(
                      backgroundColor: secondaryColor,
                      padding: const EdgeInsets.symmetric(
                          horizontal: 20, vertical: 12),
                    ),
                    child: Text(
                      _chatSummary == null
                          ? 'Generate Summary'
                          : 'Regenerate Summary',
                      style: const TextStyle(
                        color: Colors.white,
                        fontWeight: FontWeight.bold,
                      ),
                    ),
                  ),
                ),
              ],
            ),
          ),
        ),
      ),
    );
  }

  // Consolidated sentiment history item builder function
  Widget _buildSentimentHistoryItemFixed({
    required String text,
    required String sentiment,
    Timestamp? timestamp,
  }) {
    // Normalize sentiment to lowercase for case-insensitive comparison
    final normalizedSentiment = sentiment.toLowerCase();
    print('Building sentiment history item for: $normalizedSentiment');

    // Get sentiment color and emoji
    Color color;
    String emoji;
    String sentimentText;
    
    // Handle all sentiment variations
    if (normalizedSentiment == 'very positive') {
      color = Colors.green.shade700;
      emoji = '😄';
      sentimentText = 'Very Positive';
    } else if (normalizedSentiment == 'positive' || normalizedSentiment == 'pos') {
      color = Colors.green;
      emoji = '😊';
      sentimentText = 'Positive';
    } else if (normalizedSentiment == 'neutral' || normalizedSentiment == 'neu') {
      color = Colors.blue;
      emoji = '😐';
      sentimentText = 'Neutral';
    } else if (normalizedSentiment == 'negative' || normalizedSentiment == 'neg') {
      color = Colors.red;
      emoji = '😔';
      sentimentText = 'Negative';
    } else if (normalizedSentiment == 'very negative') {
      color = Colors.red.shade900;
      emoji = '😭';
      sentimentText = 'Very Negative';
    } else {
      // Default fallback
      color = Colors.blue;
      emoji = '🤔';
      sentimentText = 'Unknown';
    }

    // Format timestamp
    String timeString = 'Unknown time';
    if (timestamp != null) {
      final date = timestamp.toDate();
      timeString = DateFormat('MMM d, yyyy • h:mm a').format(date);
    }

    return Container(
      margin: const EdgeInsets.symmetric(vertical: 6),
      decoration: BoxDecoration(
        borderRadius: BorderRadius.circular(12),
        color: Colors.white.withOpacity(0.1),
      ),
      child: Padding(
        padding: const EdgeInsets.all(12.0),
        child: Row(
          children: [
            Container(
              padding: const EdgeInsets.all(8),
              decoration: BoxDecoration(
                shape: BoxShape.circle,
                color: color.withOpacity(0.2),
              ),
              child: Text(
                emoji,
                style: const TextStyle(fontSize: 20),
              ),
            ),
            const SizedBox(width: 12),
            Expanded(
              child: Column(
                crossAxisAlignment: CrossAxisAlignment.start,
                children: [
                  Text(
                    sentimentText,
                    style: const TextStyle(
                      color: Colors.white,
                      fontSize: 16,
                      fontWeight: FontWeight.bold,
                    ),
                  ),
                  const SizedBox(height: 4),
                  Text(
                    timeString,
                    style: TextStyle(
                      color: Colors.white.withOpacity(0.7),
                      fontSize: 12,
                    ),
                  ),
                ],
              ),
            ),
            Container(
              width: 45,
              height: 45,
              decoration: BoxDecoration(
                shape: BoxShape.circle,
                border: Border.all(color: color, width: 2),
                gradient: RadialGradient(
                  colors: [
                    color.withOpacity(0.5),
                    color.withOpacity(0.2),
                  ],
                ),
              ),
              child: Center(
                child: Text(
                  normalizedSentiment == 'very positive'
                      ? '+++'
                      : normalizedSentiment == 'positive' || normalizedSentiment == 'pos'
                          ? '++'
                          : normalizedSentiment == 'neutral' || normalizedSentiment == 'neu'
                              ? '~'
                              : normalizedSentiment == 'negative' || normalizedSentiment == 'neg'
                                  ? '--'
                                  : normalizedSentiment == 'very negative'
                                      ? '---'
                                      : '?',
                  style: const TextStyle(
                    color: Colors.white,
                    fontSize: 18,
                    fontWeight: FontWeight.bold,
                  ),
                ),
              ),
            ),
          ],
        ),
      ),
    );
  }
}
