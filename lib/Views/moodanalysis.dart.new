  }

  Widget _buildSentimentStatRow() {
    final total = _sentimentDistribution.values.fold(0, (sum, count) => sum + count);
    if (total == 0) {
      return const Text(
        "No data available",
        style: TextStyle(color: Colors.white70),
      );
    }

    // Combine legacy and new categories
    final veryPositiveCount = _sentimentDistribution['very positive'] ?? 0;
    final positiveCount = (_sentimentDistribution['positive'] ?? 0) +
        (_sentimentDistribution['pos'] ?? 0);
    final neutralCount = (_sentimentDistribution['neutral'] ?? 0) +
        (_sentimentDistribution['neu'] ?? 0);
    final negativeCount = (_sentimentDistribution['negative'] ?? 0) +
        (_sentimentDistribution['neg'] ?? 0);
    final veryNegativeCount = _sentimentDistribution['very negative'] ?? 0;

    return Row(
      mainAxisAlignment: MainAxisAlignment.spaceAround,
      children: [
        _buildSentimentStat("Very+", veryPositiveCount, Colors.green.shade700),
        _buildSentimentStat("Pos", positiveCount, Colors.green),
        _buildSentimentStat("Neu", neutralCount, Colors.blue),
        _buildSentimentStat("Neg", negativeCount, Colors.red),
        _buildSentimentStat("Very-", veryNegativeCount, Colors.red.shade900),
      ],
    );
  }

  Widget _buildSentimentStat(String label, int count, Color color) {
    return Column(
      children: [
        Text(
          count.toString(),
          style: TextStyle(
            color: color,
            fontSize: 16,
            fontWeight: FontWeight.bold,
          ),
        ),
        Text(
          label,
          style: TextStyle(
            color: Colors.white.withOpacity(0.7),
            fontSize: 12,
          ),
        ),
      ],
    );
  }

  Widget _buildPieChart() {
    final total = _sentimentDistribution.values.fold(0, (sum, count) => sum + count);
    if (total == 0) {
      return const Center(
        child: Text(
          "No data",
          style: TextStyle(color: Colors.white70),
        ),
      );
    }

    // Combine legacy and new categories
    final veryPositiveCount = _sentimentDistribution['very positive'] ?? 0;
    final positiveCount = (_sentimentDistribution['positive'] ?? 0) +
        (_sentimentDistribution['pos'] ?? 0);
    final neutralCount = (_sentimentDistribution['neutral'] ?? 0) +
        (_sentimentDistribution['neu'] ?? 0);
    final negativeCount = (_sentimentDistribution['negative'] ?? 0) +
        (_sentimentDistribution['neg'] ?? 0);
    final veryNegativeCount = _sentimentDistribution['very negative'] ?? 0;

    return PieChart(
      PieChartData(
        sectionsSpace: 2,
        centerSpaceRadius: 20,
        sections: [
          if (veryPositiveCount > 0)
            PieChartSectionData(
              color: Colors.green.shade700,
              value: veryPositiveCount.toDouble(),
              title: '',
              radius: 40,
            ),
          if (positiveCount > 0)
            PieChartSectionData(
              color: Colors.green,
              value: positiveCount.toDouble(),
              title: '',
              radius: 40,
            ),
          if (neutralCount > 0)
            PieChartSectionData(
              color: Colors.blue,
              value: neutralCount.toDouble(),
              title: '',
              radius: 40,
            ),
          if (negativeCount > 0)
            PieChartSectionData(
              color: Colors.red,
              value: negativeCount.toDouble(),
              title: '',
              radius: 40,
            ),
          if (veryNegativeCount > 0)
            PieChartSectionData(
              color: Colors.red.shade900,
              value: veryNegativeCount.toDouble(),
              title: '',
              radius: 40,
            ),
        ],
      ),
    );
  }

