import 'package:flutter/material.dart';
import 'package:fl_chart/fl_chart.dart';
import 'package:therapylink/Views/custom_app_bar.dart';
import 'package:therapylink/utils/colors.dart';
import 'package:cloud_firestore/cloud_firestore.dart';
import 'package:firebase_auth/firebase_auth.dart';
import 'dart:ui';
import 'package:intl/intl.dart';
import 'package:therapylink/services/summary_service.dart';

class MoodAnalysisPage extends StatefulWidget {
  const MoodAnalysisPage({super.key});

  @override
  State<MoodAnalysisPage> createState() => _MoodAnalysisPageState();
}

class _MoodAnalysisPageState extends State<MoodAnalysisPage>
    with SingleTickerProviderStateMixin {
  final List<String> timeFrames = ['Week', 'Month', 'Year'];
  String selectedTimeFrame = 'Week';

  late AnimationController _animationController;
  late Animation<double> _fadeAnimation;
  late Animation<Offset> _slideAnimation;

  // Data storage for sentiment analytics
  Map<String, int> _sentimentDistribution = {
    'very positive': 0,
    'positive': 0,
    'neutral': 0,
    'negative': 0,
    'very negative': 0,
    // Legacy support for old values
    'pos': 0,
    'neg': 0,
    'neu': 0,
  };

  // For line chart data by day
  List<FlSpot> _weeklySpots = [];
  List<FlSpot> _monthlySpots = [];
  List<FlSpot> _yearlySpots = [];

  // Loading state
  bool _isLoading = true;
  String _error = '';

  // State variables for summarization
  bool _isSummarizing = false;
  String? _chatSummary;

  // Stream subscription for real-time updates
  Stream<QuerySnapshot>? _sentimentStream;

  @override
  void initState() {
    super.initState();
    _animationController = AnimationController(
      vsync: this,
      duration: const Duration(milliseconds: 1000),
    );
    _fadeAnimation = CurvedAnimation(
      parent: _animationController,
      curve: const Interval(0.0, 0.7, curve: Curves.easeOut),
    );
    _slideAnimation = Tween<Offset>(
      begin: const Offset(0, 0.2),
      end: Offset.zero,
    ).animate(CurvedAnimation(
      parent: _animationController,
      curve: const Interval(0.0, 0.8, curve: Curves.easeOut),
    ));

    _setupSentimentStream();
    _animationController.forward();
  }

  @override
  void didChangeDependencies() {
    super.didChangeDependencies();
    // Refresh data when returning to this page
    if (!_isLoading && _error.isEmpty) {
      _loadSentimentData();
    }
  }

  // Setup real-time stream for sentiment data
  void _setupSentimentStream() {
    final user = FirebaseAuth.instance.currentUser;
    if (user != null) {
      print("Setting up sentiment stream for user: ${user.uid}");
      _sentimentStream = FirebaseFirestore.instance
          .collection('users')
          .doc(user.uid)
          .collection('sentiments')
          .orderBy('timestamp', descending: true)
          .limit(20) // Limit to last 20 for better performance
          .snapshots()
          .handleError((error) {
        print("Error in sentiment stream: $error");
        setState(() {
          _isLoading = false;
          _error = 'Failed to load data: $error';
        });
      });

      // Listen to the stream
      _loadSentimentData();
    } else {
      setState(() {
        _isLoading = false;
        _error = 'User not signed in';
      });
    }
  }

  // Load sentiment data from Firestore
  Future<void> _loadSentimentData() async {
    setState(() {
      _isLoading = true;
      _error = '';
    });

    try {
      final user = FirebaseAuth.instance.currentUser;
      if (user == null) {
        setState(() {
          _isLoading = false;
          _error = 'User not signed in';
        });
        return;
      }

      // Reset distribution map
      _sentimentDistribution = {
        'very positive': 0,
        'positive': 0,
        'neutral': 0,
        'negative': 0,
        'very negative': 0,
        'pos': 0,
        'neu': 0,
        'neg': 0,
      };

      // Reset chart data
      _weeklySpots = [];
      _monthlySpots = [];
      _yearlySpots = [];

      // Get current date for time frame calculations
      final now = DateTime.now();
      final oneWeekAgo = now.subtract(const Duration(days: 7));
      final oneMonthAgo = DateTime(now.year, now.month - 1, now.day);
      final oneYearAgo = DateTime(now.year - 1, now.month, now.day);

      // We'll fetch all data for the past year and filter in memory for efficiency
      final QuerySnapshot snapshot = await FirebaseFirestore.instance
          .collection('users')
          .doc(user.uid)
          .collection('sentiments')
          .orderBy('timestamp', descending: true)
          .get();

      // Process the snapshot data
      _processSentimentData(snapshot.docs, oneWeekAgo, oneMonthAgo, oneYearAgo);

      setState(() {
        _isLoading = false;
      });
    } catch (e) {
      print("Error loading sentiment data: $e");
      setState(() {
        _isLoading = false;
        _error = 'Failed to load data: $e';
      });
    }
  }

  // Process sentiment documents
  void _processSentimentData(
    List<QueryDocumentSnapshot> docs,
    DateTime oneWeekAgo,
    DateTime oneMonthAgo,
    DateTime oneYearAgo,
  ) {
    if (docs.isEmpty) return;

    // Create maps to store daily averages
    Map<DateTime, List<double>> weeklyScores = {};
    Map<DateTime, List<double>> monthlyScores = {};
    Map<DateTime, List<double>> yearlyScores = {};

    // Process each document
    for (var doc in docs) {
      final data = doc.data() as Map<String, dynamic>;
      final timestamp = data['timestamp'] as Timestamp;
      final sentiment = (data['sentiment'] as String).toLowerCase();

      // Update distribution counters
      _updateDistributionCount(sentiment);

      // Convert timestamp to DateTime
      final date = timestamp.toDate();
      final day = DateTime(date.year, date.month, date.day);

      // Calculate sentiment score (higher is more positive)
      double score = _calculateSentimentScore(sentiment);

      // Update daily averages for different time frames
      if (date.isAfter(oneWeekAgo)) {
        weeklyScores.putIfAbsent(day, () => []).add(score);
      }
      if (date.isAfter(oneMonthAgo)) {
        monthlyScores.putIfAbsent(day, () => []).add(score);
      }
      if (date.isAfter(oneYearAgo)) {
        yearlyScores.putIfAbsent(day, () => []).add(score);
      }
    }

    // Generate line chart data points
    _weeklySpots = _generateLineChartData(weeklyScores, oneWeekAgo);
    _monthlySpots = _generateLineChartData(monthlyScores, oneMonthAgo);
    _yearlySpots = _generateLineChartData(yearlyScores, oneYearAgo);
  }

  // Update sentiment distribution counter
  void _updateDistributionCount(String sentiment) {
    // Handle the 5 new sentiment categories as well as legacy categories
    if (_sentimentDistribution.containsKey(sentiment)) {
      _sentimentDistribution[sentiment] = (_sentimentDistribution[sentiment] ?? 0) + 1;
    }
  }

  // Calculate sentiment score
  double _calculateSentimentScore(String sentiment) {
    // Assign scores on a scale (higher is more positive)
    if (sentiment == 'very positive') {
      return 6.0;
    } else if (sentiment == 'positive' || sentiment == 'pos') {
      return 5.0;
    } else if (sentiment == 'neutral' || sentiment == 'neu') {
      return 3.0;
    } else if (sentiment == 'negative' || sentiment == 'neg') {
      return 1.0;
    } else if (sentiment == 'very negative') {
      return 0.0;
    }
    // Default if we encounter an unknown sentiment
    return 3.0;
  }

  // Generate line chart data
  List<FlSpot> _generateLineChartData(
    Map<DateTime, List<double>> dailyScores,
    DateTime startDate,
  ) {
    List<FlSpot> spots = [];
    final now = DateTime.now();
    final daysInPeriod = now.difference(startDate).inDays;

    // Calculate day ranges
    for (int i = 0; i <= daysInPeriod; i++) {
      final day = DateTime(
        startDate.year,
        startDate.month,
        startDate.day + i,
      );
      if (dailyScores.containsKey(day) && dailyScores[day]!.isNotEmpty) {
        // Calculate average score for this day
        final avgScore = dailyScores[day]!.reduce((a, b) => a + b) /
            dailyScores[day]!.length;
        spots.add(FlSpot(i.toDouble(), avgScore));
      } else {
        // No data for this day, can add null spot for gaps
        // or interpolate based on adjacent days
      }
    }

    return spots;
  }

  @override
  void dispose() {
    _animationController.dispose();
    super.dispose();
  }

  // Handle time frame selection
  void _selectTimeFrame(String timeFrame) {
    setState(() {
      selectedTimeFrame = timeFrame;
    });
  }

  // Generate overall sentiment status text
  String _getSentimentStatusText() {
    // Calculate total entries with a preference for the new sentiment format
    int total = _sentimentDistribution.values.fold(0, (sum, count) => sum + count);
    
    if (total == 0) return "Not enough data";

    // Calculate percentage of positive sentiments
    int positiveCount = (_sentimentDistribution['very positive'] ?? 0) +
        (_sentimentDistribution['positive'] ?? 0) +
        (_sentimentDistribution['pos'] ?? 0);
    int negativeCount = (_sentimentDistribution['very negative'] ?? 0) +
        (_sentimentDistribution['negative'] ?? 0) +
        (_sentimentDistribution['neg'] ?? 0);
    
    double positivePercentage = (positiveCount / total) * 100;
    double negativePercentage = (negativeCount / total) * 100;

    // Determine overall status
    if (positivePercentage > 60) {
      return "Overall Positive";
    } else if (positivePercentage > 40 && negativePercentage < 40) {
      return "Moderately Positive";
    } else if (negativePercentage > 60) {
      return "Overall Negative";
    } else if (negativePercentage > 40 && positivePercentage < 40) {
      return "Moderately Negative";
    } else {
      return "Balanced";
    }
  }

  // Calculate color based on sentiment distribution
  Color _getMoodColor() {
    // Similar logic to status text, but returns a color
    int total = _sentimentDistribution.values.fold(0, (sum, count) => sum + count);
    if (total == 0) return Colors.blue;

    int positiveCount = (_sentimentDistribution['very positive'] ?? 0) +
        (_sentimentDistribution['positive'] ?? 0) +
        (_sentimentDistribution['pos'] ?? 0);
    int negativeCount = (_sentimentDistribution['very negative'] ?? 0) +
        (_sentimentDistribution['negative'] ?? 0) +
        (_sentimentDistribution['neg'] ?? 0);
    
    double positivePercentage = (positiveCount / total) * 100;
    double negativePercentage = (negativeCount / total) * 100;

    if (positivePercentage > 60) {
      return Colors.green;
    } else if (positivePercentage > 40 && negativePercentage < 40) {
      return Colors.lightGreen;
    } else if (negativePercentage > 60) {
      return Colors.red;
    } else if (negativePercentage > 40 && positivePercentage < 40) {
      return Colors.orange;
    } else {
      return Colors.blue;
    }
  }

  Future<void> _summarizeChatHistory() async {
    if (_isSummarizing) return;

    setState(() {
      _isSummarizing = true;
    });

    try {
      final user = FirebaseAuth.instance.currentUser;
      if (user == null) {
        throw Exception('User not signed in');
      }

      // Get chat history
      final QuerySnapshot snapshot = await FirebaseFirestore.instance
          .collection('users')
          .doc(user.uid)
          .collection('messages')
          .orderBy('timestamp', descending: true)
          .limit(50)
          .get();

      List<String> messages = snapshot.docs
          .map((doc) {
            final data = doc.data() as Map<String, dynamic>;
            final message = data['message'] as String?;
            final sender = data['sender'] as String?;
            return sender == 'user' ? message : null;
          })
          .where((message) => message != null)
          .map((message) => message!)
          .toList();

      if (messages.isEmpty) {
        throw Exception('No messages found');
      }

      // Use the summary service to generate a summary
      final summary = await SummaryService().summarizeText(messages.join(' '));

      setState(() {
        _chatSummary = summary;
        _isSummarizing = false;
      });
    } catch (e) {
      print('Error summarizing chat: $e');
      setState(() {
        _chatSummary = 'Failed to generate summary: $e';
        _isSummarizing = false;
      });
    }
  }

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      backgroundColor: primaryColor,
      appBar: CustomAppBar(title: 'Mood Analytics', showBackButton: true),
      body: _isLoading
          ? const Center(child: CircularProgressIndicator(color: Colors.white))
          : _error.isNotEmpty
              ? Center(
                  child: Padding(
                    padding: const EdgeInsets.all(20.0),
                    child: Column(
                      mainAxisAlignment: MainAxisAlignment.center,
                      children: [
                        const Icon(Icons.error_outline,
                            size: 60, color: Colors.red),
                        const SizedBox(height: 16),
                        Text(_error,
                            style: const TextStyle(color: Colors.white),
                            textAlign: TextAlign.center),
                        const SizedBox(height: 20),
                        ElevatedButton(
                          onPressed: _loadSentimentData,
                          style: ElevatedButton.styleFrom(
                            backgroundColor: secondaryColor,
                          ),
                          child: const Text('Retry'),
                        ),
                      ],
                    ),
                  ),
                )
              : SafeArea(
                  child: FadeTransition(
                    opacity: _fadeAnimation,
                    child: SlideTransition(
                      position: _slideAnimation,
                      child: SingleChildScrollView(
                        physics: const BouncingScrollPhysics(),
                        child: Padding(
                          padding: const EdgeInsets.all(16.0),
                          child: Column(
                            crossAxisAlignment: CrossAxisAlignment.start,
                            children: [
                              _buildMoodCard(),
                              const SizedBox(height: 20),
                              _buildPsychologicalTestScores(),
                              const SizedBox(height: 20),
                              _buildTrendCard(),
                              const SizedBox(height: 20),
                              _buildSentimentHistoryCard(),
                              const SizedBox(height: 20),
                              _buildSummaryCard(),
                            ],
                          ),
                        ),
                      ),
                    ),
                  ),
                ),
    );
  }

